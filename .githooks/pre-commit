#!/usr/bin/env bash

./.githooks/check-disallowed-terms.sh || exit 1  # guarding-commits-check

#
# pre-commit — delegate to scripts/bump-plugin-versions.ts, which bumps a
# plugin's patch version only when that plugin's contents actually changed
# in the staged set. Keeps the hook itself trivial so the real logic is
# reusable outside git (e.g., for manual verification).

set -euo pipefail

root="$(git rev-parse --show-toplevel)"

if ! command -v bun >/dev/null 2>&1; then
    echo "pre-commit: bun is required to run scripts/bump-plugin-versions.ts" >&2
    exit 1
fi

exec bun "$root/scripts/bump-plugin-versions.ts"
