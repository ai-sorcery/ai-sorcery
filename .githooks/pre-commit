#!/usr/bin/env bash

./.githooks/check-disallowed-terms.sh || exit 1  # guarding-commits-check
./.githooks/check-no-python.sh || exit 1
./.githooks/check-no-perl.sh || exit 1

#
# pre-commit — delegate to scripts under scripts/ and one sorcery-dev guard.
# Each script keeps its real logic reusable outside git (so they can be run
# by hand for manual verification):
#   - sort-readme-examples.ts     alphabetizes the Examples subsections
#   - update-readme-toc.ts        keeps the Examples TOC in sync
#   - check-readme-skill-links.ts enforces that every public skill has a
#                                 heading link to its README and every link
#                                 to a skill README resolves
#   - check-skill-coverage.ts     blocks commits that add a public skill
#                                 without wiring it into the demoing-sorcery-skills
#                                 runbook — lives under sorcery-dev but runs
#                                 repo-wide so the contract can't be bypassed
#   - bump-plugin-versions.ts     bumps a plugin's patch version when its
#                                 contents actually changed in the staged set
# sort-readme-examples runs before update-readme-toc so the TOC reflects
# the sorted order. check-readme-skill-links runs after both so it sees the
# final README state.

set -euo pipefail

root="$(git rev-parse --show-toplevel)"

if ! command -v bun >/dev/null 2>&1; then
    echo "pre-commit: bun is required to run scripts under scripts/" >&2
    exit 1
fi

bun "$root/scripts/sort-readme-examples.ts"
bun "$root/scripts/update-readme-toc.ts"
bun "$root/scripts/check-readme-skill-links.ts"
bun "$root/plugins/sorcery-dev/skills/demoing-sorcery-skills/check-skill-coverage.ts"
exec bun "$root/scripts/bump-plugin-versions.ts"
