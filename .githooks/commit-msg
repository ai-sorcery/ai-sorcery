#!/usr/bin/env bash

./.githooks/check-disallowed-terms.sh --message "$1" || exit 1  # guarding-commits-check

#
# commit-msg — enforce conventional commits via the plugin's canonical
# `conventional-commit-check.sh`, then layer the ai-sorcery-specific
# rejection of `Co-Authored-By: Claude ...` trailers on top.
#
# Claude attribution in this repo flows through the commit author field
# (see me.sh), not a trailer.

set -euo pipefail

commit_msg_file="$1"
root="$(git rev-parse --show-toplevel)"

# Delegate conventional-commits enforcement to the plugin's canonical
# script. Types match AGENTS.md § Axioms § 2 — add new types to both
# places if the project grows.
CONVENTIONAL_TYPES='feat,fix,refactor,docs,chore' \
  "$root/plugins/sorcery/guarding-commits/conventional-commit-check.sh" "$commit_msg_file"

# Project-specific: reject Co-Authored-By: Claude trailers. Human
# co-authors are still fine.
msg="$(git stripspace --strip-comments <"$commit_msg_file")"
if printf '%s\n' "$msg" | grep -qi '^co-authored-by:.*claude'; then
  cat >&2 <<EOF
Error: "Co-Authored-By: Claude ..." trailer is not allowed.
       Attribute Claude via the commit author field instead.
EOF
  exit 1
fi
