#!/usr/bin/env bash
#
# commit-msg — enforce the conventional commit format described in AGENTS.md.
#
# The subject line must look like `type(scope): subject`, with scope
# optional. If a body follows, it must be separated from the subject by a
# blank line; inside the body, hyphen bullets and any other markdown are
# fine. Auto-generated messages from merges, reverts, and fixup/squash
# commits are skipped.

set -euo pipefail

commit_msg_file="$1"

# git adds instructional comment lines ("# Please enter the commit message...")
# and trailing whitespace. Strip them before inspecting the real message.
msg=$(git stripspace --strip-comments <"$commit_msg_file")

first_line=$(printf '%s\n' "$msg" | head -n 1)

# Merge/revert/fixup/squash commits have auto-generated subjects that
# don't follow the conventional format; let them through.
if [[ "$first_line" =~ ^(Merge|Revert|fixup!|squash!) ]]; then
    exit 0
fi

# Types match AGENTS.md § Axioms § 2. Add new types to both places.
subject_pattern='^(feat|fix|refactor|docs|chore)(\([a-z0-9-]+\))?: .+'

if ! [[ "$first_line" =~ $subject_pattern ]]; then
    cat >&2 <<EOF
Error: commit subject does not follow conventional commits.

  Expected: type(scope): subject   (scope optional)
  Types:    feat, fix, refactor, docs, chore
  Got:      $first_line
EOF
    exit 1
fi

# When a body is present, the second line must be blank so the subject
# is clearly separated. sed -n '2p' prints line 2 or nothing for a
# single-line message; either way the check is correct.
second_line=$(printf '%s\n' "$msg" | sed -n '2p')
if [[ -n "$second_line" ]]; then
    echo "Error: separate commit body from subject with a blank line." >&2
    exit 1
fi
